---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import MultiStepBooking from '../components/MultiStepBooking';
---

<BaseLayout title="Book a Quiz Experience | QShala">
  <Navbar />
  <main class="flex-grow pt-32 pb-24 px-6">
    <div class="max-w-7xl mx-auto space-y-12">
      <div class="text-center max-w-3xl mx-auto">
        <span class="px-4 py-1.5 rounded-full bg-[#FDB913] text-black font-black text-xs uppercase tracking-wider border border-black font-heading">
          Interactive Booking Wizard
        </span>
        <h1 class="text-4xl sm:text-6xl font-black text-slate-900 tracking-tight mt-3 font-heading">
          Book a <span class="text-[#30B2E7]">Curiosity Experience.</span>
        </h1>
        <p class="text-slate-700 text-lg mt-3 font-semibold">
          Tell us about your audience and preferences, and our quiz masters will craft an unforgettable experience.
        </p>
      </div>

      <!-- React Island Hydrated client:idle for optimal LCP -->
      <MultiStepBooking client:idle />
    </div>
  </main>
  <Footer />
</BaseLayout>
