---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact Us | QShala">
  <Navbar />
  <main class="flex-grow pt-32 pb-24 px-6">
    <div class="max-w-7xl mx-auto space-y-12">
      <div class="text-center max-w-3xl mx-auto">
        <span class="px-4 py-1.5 rounded-full bg-[#75B543] text-white font-black text-xs uppercase border border-black font-heading">Get in Touch</span>
        <h1 class="text-4xl sm:text-6xl font-black text-slate-900 mt-4 font-heading">We&apos;re All Ears for Your Questions</h1>
      </div>

      <div class="max-w-xl mx-auto bg-white rounded-3xl p-8 border-2 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] space-y-4">
        <div>
          <label class="block text-xs font-black uppercase mb-1">Your Name</label>
          <input type="text" class="w-full px-4 py-3 rounded-2xl border-2 border-black bg-[#FFFDF5]" placeholder="Pavan Kumar" />
        </div>
        <div>
          <label class="block text-xs font-black uppercase mb-1">Email</label>
          <input type="email" class="w-full px-4 py-3 rounded-2xl border-2 border-black bg-[#FFFDF5]" placeholder="pavan@example.com" />
        </div>
        <div>
          <label class="block text-xs font-black uppercase mb-1">Message</label>
          <textarea rows="4" class="w-full px-4 py-3 rounded-2xl border-2 border-black bg-[#FFFDF5]" placeholder="How can we help your school or company?"></textarea>
        </div>
        <button type="submit" class="w-full py-3 bg-[#FDB913] text-black font-black rounded-2xl border-2 border-black font-heading shadow-md">
          Send Message →
        </button>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
